# Fuseau horaire pour la fenêtre humaine (défaut: Europe/Paris)
SUPERSOCIAL_TIMEZONE=Europe/Paris

# Profil de throttling: "conservative" (défaut), "normal", "aggressive" (à éviter)
SUPERSOCIAL_THROTTLE_PROFILE=conservative

# Dossier racine pour le profil Chrome persistant (cookies, local storage, cache)
# Relatif à la racine du projet par défaut
SUPERSOCIAL_CHROME_PROFILE_DIR=.chrome-profile

# Mode headless (false recommandé pour observer et éviter la détection)
SUPERSOCIAL_HEADLESS=false

# Désactiver le plugin stealth (utile pour debug)
# SUPERSOCIAL_STEALTH=false
